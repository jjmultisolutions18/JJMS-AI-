rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('ADMIN');
    }

    // Public Connectivity Test
    match /test/connection {
      allow get: if true;
    }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['ADMIN', 'LINE MANAGER', 'PROGRAMME COORDINATOR', 'MENTOR', 'INNOVATOR'];
    }

    function isValidInnovation(data) {
      return data.keys().hasAll(['title', 'innovatorId', 'stage']) &&
             data.title is string && data.title.size() <= 200 &&
             data.innovatorId == request.auth.uid &&
             data.stage in ['STAGE 0: Pipeline & Awareness', 'STAGE 1: Ideation', 'STAGE 2: Technology Development', 'STAGE 3: Commercialisation'];
    }

    // --- Match Blocks ---

    // USERS
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName']) &&
                      isValidUser(incoming());
      allow delete: if isAdmin();
    }

    // INNOVATIONS
    match /innovations/{innovationId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.innovatorId == request.auth.uid || isAdmin() || hasRole('PROGRAMME COORDINATOR'));
      allow create: if isSignedIn() && isEmailVerified() && isValidInnovation(incoming());
      allow update: if isSignedIn() && (
                      (isOwner(existing().innovatorId) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'problem', 'solution', 'targetMarket', 'stage', 'updatedAt'])) ||
                      isAdmin()
                    ) && isValidInnovation(incoming());
      allow delete: if isAdmin() || (isSignedIn() && isOwner(existing().innovatorId));
    }

    // PROGRAMMES
    match /programmes/{programmeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || hasRole('LINE MANAGER');
    }

    // EVALUATIONS
    match /evaluations/{evaluationId} {
      allow read: if isSignedIn() && (
                      isOwner(get(/databases/$(database)/documents/innovations/$(resource.data.innovationId)).data.innovatorId) ||
                      hasRole('PROGRAMME COORDINATOR') || 
                      isAdmin()
                    );
      allow create: if isSignedIn() && (hasRole('PROGRAMME COORDINATOR') || hasRole('MENTOR') || isAdmin());
    }
  }
}
